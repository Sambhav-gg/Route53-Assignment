# ─── Backend environment (copy to backend/.env on the server) ───────────────

# REQUIRED in production. Generate a strong random key:
#   openssl rand -hex 32
SECRET_KEY=change-me-generate-a-strong-random-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# SQLite database. Relative paths resolve against the backend working directory
# (set by the systemd unit). Use an absolute path to be explicit, e.g.
#   DATABASE_URL=sqlite:////opt/route53-clone/backend/route53.db
DATABASE_URL=sqlite:///./route53.db

# Allowed CORS origins (comma-separated). For a same-origin nginx deploy the
# frontend and API share one origin, so CORS is not exercised — the default is
# fine. For a SEPARATE frontend domain, list it here, e.g.
#   CORS_ORIGINS=https://route53.example.com
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Cookie hardening. Set COOKIE_SECURE=true ONLY when serving over HTTPS,
# otherwise the browser will drop the session cookie on plain HTTP.
COOKIE_SECURE=false
COOKIE_SAMESITE=lax
